FINRADAR Configuration
Copy to .env and fill values

LLM_API_KEYS:
ANTHROPIC_API_KEY=your_claude_key
OPENAI_API_KEY=your_openai_key

DATABASE:
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/finradar
REDIS_URL=redis://localhost:6379/0

VECTOR_STORE:
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=finradar_docs

FINANCIAL_APIS:
SEC_USER_AGENT=FinRadar contact@finradar.ai
ALPHA_VANTAGE_KEY=your_alpha_vantage_key
FRED_API_KEY=your_fred_key
NEWS_API_KEY=your_newsapi_key

STARTUP_DISCOVERY:
CRUNCHBASE_API_KEY=your_crunchbase_key
LINKEDIN_EMAIL=your_email
LINKEDIN_PASSWORD=your_password

SCHEDULING:
DAILY_REPORT_TIME=09:00
WEEKLY_SCAN_DAY=MONDAY
SCAN_INTERVAL_HOURS=24

ALERTS:
SLACK_WEBHOOK_URL=
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=
EMAIL_PASSWORD=

API:
API_HOST=0.0.0.0
API_PORT=8001
API_KEY=your_api_key

DSPY:
DSPY_LM_MODEL=openai/gpt-4o-mini
DSPY_LM_TEMPERATURE=0.0

LOGGING:
LOG_LEVEL=INFO
LOG_FORMAT=json
